# OS-level thread stack cap. Lets `node --stack-size=N` actually
# allocate the larger stack — without this, V8 silently clamps and
# pickles' compiled recursion still blows up.
#
# `--stack-size` is NOT on Node's NODE_OPTIONS whitelist (don't try
# to set it here), so invoke it on the command line per-run.
ulimit -s unlimited
