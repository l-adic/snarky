*.d.ts
*.js.map
# …but the bench harness's hand-written TS contract is source, not generated.
!bench/harness/index.d.ts

# Purescript Spec
.spec-results

# The on-disk SRS-files dir, populated by `make fetch-srs` (the kimchi `.srs`
# URS blobs). Anchored to the repo root.
/srs-cache/

# The on-disk Lagrange-basis cache dir (CI points SNARK_LAGRANGE_CACHE_DIR here
# so actions/cache can persist it across runs). Anchored to the repo root; the
# `lagrange-cache` PACKAGE source lives under packages/ and stays tracked.
/lagrange-cache/

# Crypto provider symlink (removed - now using real crate)

# Generated linearization files
packages/pickles/src/Pickles/Linearization/Pallas.purs
packages/pickles/src/Pickles/Linearization/Vesta.purs
packages/pickles-codegen/rust/output/

# Developer debug artifacts — regenerated on demand via
# `tools/regen-fixtures.sh`. Consumed only by the manual convergence
# diff scripts in `tools/`, not by the automated test suite.
packages/pickles/test/fixtures/*.trace
# All OCaml/PS witness dumps are local convergence artifacts (witness/,
# witness_nrr/, witness_chunks2/, witness_chunks4/, witness_sideload/, ...).
packages/pickles/test/fixtures/witness*/

# Generated dependency graph
deps.svg
deps.dot
deps.json

# Generated module-inventory analysis (produced by pickles-inventory.js)
analysis/

# Presentation
presentation/

tools/__pycache__/

# Circuit-diff OCaml fixtures: committed in gzipped form ONLY (~13MB vs
# ~325MB raw). The plain .json/.jsonl are local working copies,
# materialised by `make fixtures-unpack` (a prerequisite of
# `make test-pickles-circuit-diffs`). Regenerate via the OCaml dump
# drivers / tools/regen_chunks_fixtures.sh, then `make fixtures-pack`
# and commit the *.gz. (`*.json` does not match `*.json.gz`, so the
# compressed artifacts stay tracked.)
packages/pickles-circuit-diffs/circuits/ocaml/*.json
packages/pickles-circuit-diffs/circuits/ocaml/*.jsonl
bench-results/
prof/

# Profiling visualizations: commit PNGs; SVGs are large/regenerable (tools/profile/)
bench/profiles/*.svg
