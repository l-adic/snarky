digraph "formal-modules" {
	graph [nodesep=0.25,
		rankdir=TB,
		ranksep=1.6
	];
	node [fillcolor=white,
		fontname=Helvetica,
		fontsize=10,
		shape=box,
		style=filled
	];
	edge [arrowsize=0.6,
		color=gray40
	];
	subgraph cluster_pasta {
		graph [color=gray50,
			fillcolor="#cfe8ff",
			fontname="Helvetica-Bold",
			fontsize=12,
			label=pasta,
			style=filled
		];
		"Pasta.Basic";
		"Pasta.Endo";
		Pasta;
		"Pasta.Shifted";
	}
	subgraph cluster_poseidon {
		graph [color=gray50,
			fillcolor="#d5f0d0",
			fontname="Helvetica-Bold",
			fontsize=12,
			label=poseidon,
			style=filled
		];
		FixtureKit;
		"FixtureKit.Parse";
		"FixtureKit.Trace";
		"Poseidon.Basic";
		"Poseidon.ConstantsFp";
		"Poseidon.ConstantsFq";
		"Poseidon.FqSponge";
		"Poseidon.GroupMap";
		Poseidon;
	}
	subgraph "cluster_bulletproof-pcs" {
		graph [color=gray50,
			fillcolor="#ffe0c2",
			fontname="Helvetica-Bold",
			fontsize=12,
			label="bulletproof-pcs",
			style=filled
		];
		BulletproofFixture;
		Bulletproof;
		"Bulletproof.Protocol";
		"Bulletproof.Reflection";
		"Bulletproof.Soundness";
		"Bulletproof.Soundness.SingleOpening";
		"Bulletproof.Wire";
	}
	subgraph cluster_kimchi {
		graph [color=gray50,
			fillcolor="#e6d5f0",
			fontname="Helvetica-Bold",
			fontsize=12,
			label=kimchi,
			style=filled
		];
		subgraph cluster_kimchi_Kimchi_Gate {
			graph [color=gray55,
				fillcolor=white,
				fontname="Helvetica-Oblique",
				fontsize=11,
				label="Kimchi.Gate",
				style="filled,dashed"
			];
			"Kimchi.Gate.AddComplete";
			"Kimchi.Gate.EndoMul";
			"Kimchi.Gate.EndoScalar";
			"Kimchi.Gate.Generic";
			"Kimchi.Gate.Poseidon";
			"Kimchi.Gate.Semantics.AddComplete";
			"Kimchi.Gate.Semantics.EndoMul";
			"Kimchi.Gate.Semantics.EndoScalar";
			"Kimchi.Gate.Semantics.Generic";
			"Kimchi.Gate.Semantics.Poseidon";
			"Kimchi.Gate.Semantics.VarBaseMul";
			"Kimchi.Gate.VarBaseMul";
		}
		subgraph cluster_kimchi_Kimchi_Index {
			graph [color=gray55,
				fillcolor=white,
				fontname="Helvetica-Oblique",
				fontsize=11,
				label="Kimchi.Index",
				style="filled,dashed"
			];
			"Kimchi.Index.Aggregate";
			"Kimchi.Index.Basic";
			"Kimchi.Index.CopySoundness";
			"Kimchi.Index.Degree";
			"Kimchi.Index.Satisfies";
		}
		subgraph cluster_kimchi_Kimchi_Permutation {
			graph [color=gray55,
				fillcolor=white,
				fontname="Helvetica-Oblique",
				fontsize=11,
				label="Kimchi.Permutation",
				style="filled,dashed"
			];
			"Kimchi.Permutation.Copy";
			"Kimchi.Permutation.Permutation";
			"Kimchi.Permutation.Wiring";
		}
		subgraph cluster_kimchi_Kimchi_Protocol {
			graph [color=gray55,
				fillcolor=white,
				fontname="Helvetica-Oblique",
				fontsize=11,
				label="Kimchi.Protocol",
				style="filled,dashed"
			];
			"Kimchi.Protocol.Binding";
			"Kimchi.Protocol.Correspond";
			"Kimchi.Protocol.Equation";
			"Kimchi.Protocol.Linearization";
			"Kimchi.Protocol.Soundness";
		}
		subgraph cluster_kimchi_Kimchi_Verifier {
			graph [color=gray55,
				fillcolor=white,
				fontname="Helvetica-Oblique",
				fontsize=11,
				label="Kimchi.Verifier",
				style="filled,dashed"
			];
			"Kimchi.Verifier.Capstone";
			"Kimchi.Verifier.Kimchi";
			"Kimchi.Verifier.Reflect";
		}
		"Kimchi.Aggregate";
		"Kimchi.Domain";
		"Kimchi.GrandProduct";
		Kimchi;
		"Kimchi.Lift";
		"Kimchi.SchwartzZippel";
		"Kimchi.Shifted";
	}
	subgraph cluster_snarky {
		graph [color=gray50,
			fillcolor="#ffd6d6",
			fontname="Helvetica-Bold",
			fontsize=12,
			label=snarky,
			style=filled
		];
		"Snarky.AsProver";
		"Snarky.Builder";
		"Snarky.Constraint.Basic";
		"Snarky.Constraint.R1CS";
		"Snarky.CVar";
		"Snarky.DSL";
		"Snarky.Example";
		"Snarky.Kimchi.Backend";
		"Snarky.Kimchi.Example";
		"Snarky.Laws";
		Snarky;
		"Snarky.Monad";
		"Snarky.Prover";
		"Snarky.Types";
		"Snarky.Vec";
	}
	"Pasta.Endo" -> "Pasta.Basic";
	Pasta -> "Pasta.Endo";
	Pasta -> "Pasta.Shifted";
	FixtureKit -> "FixtureKit.Trace";
	"FixtureKit.Trace" -> "FixtureKit.Parse";
